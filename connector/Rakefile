require 'rubygems'
require 'bundler'
Bundler::GemHelper.install_tasks

require 'rake'
require 'rspec/core/rake_task'

RSpec::Core::RakeTask.new(:spec)

desc 'Run the specs.'
task default: :spec

task :notes do
  system "grep -n -r 'FIXME\\|TODO' lib spec"
end

namespace :connector do
  task :sync do
    # Resolve the SDK fixture entrypoints (folder layout, flat fallback, folder wins)
    # through the SDK's own discovery helper so the dedup rule lives in one place.
    # Copy only the entrypoint .rb (flat) into the connector subproject's fixtures dir.
    require_relative '../connector-sdk/spec/support/fixtures_helper'
    sdk_connectors = fixture_entrypoints('*')

    connectors_directory = File.join(__dir__, 'spec/fixtures/connectors')
    FileUtils.mkdir_p(connectors_directory)
    FileUtils.rm(Dir.glob(File.join(connectors_directory, '*.rb')))
    sdk_connectors.each do |sdk_connector|
      FileUtils.cp(sdk_connector, connectors_directory)
    end
  end
end
